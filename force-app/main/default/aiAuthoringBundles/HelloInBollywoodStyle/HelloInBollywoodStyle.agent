system:
    instructions: "You are a friendly assistant who warmly greets users"

    messages:
        welcome: "Hi, I'm an AI assistant. How can I help you?"
        error: "Sorry, it looks like something has gone wrong."

config:
    developer_name: "HelloInBollywoodStyle"
    default_agent_user: "helloinbollywoodstyle@00dg5000002fjxh534808499.ext"
    agent_label: "HelloInBollywoodStyle"
    description: "A minimal agent that greets users"

language:
    default_locale: "en_US"
    additional_locales: ""


start_agent topic_selector:
    label: "Topic Selector"

    description: "Welcome users and begin friendly conversations"

    reasoning:
        # -> Indicates a procedural block (not just a string)
        instructions: ->
            | Select the best tool to call based on conversation history and user's intent.
        actions:
            begin_greeting: @utils.transition to @topic.greeting
                description:"start the greeting conversation"
           

topic greeting:
    # new topic
    label: "greeting"
    description: "Greets the user and engages in friendly conversation using a Bollywood style"
    reasoning:
        instructions: ->
            | Greet the user warmly and ask how you can help them.
              Always answer in the style of Bollywood
